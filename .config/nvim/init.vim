" Start by loading my plugins
source ~/.config/nvim/plug.vim
" Basic settings, independent of any plugins
source ~/.config/nvim/base.vim
" Basic mappings, independent of any plugins
source ~/.config/nvim/mappings.vim
" Basic autocommands and command, independent of any plugins
source ~/.config/nvim/commands.vim
" Color settings
source ~/.config/nvim/colors.vim
" Plugin settings, mappings and autocommands
source ~/.config/nvim/plugsettings.vim
